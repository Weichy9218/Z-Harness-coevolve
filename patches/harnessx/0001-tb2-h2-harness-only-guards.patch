--- a/benchmarks/terminal_bench_2/harness.py
+++ b/benchmarks/terminal_bench_2/harness.py
@@ -20,6 +20,7 @@ from __future__ import annotations
 
 import dataclasses
 import re
+import shlex
 import time
 import uuid
 
@@ -75,6 +76,92 @@ _EDIT_LIMIT_WARN = (
     "You are over-editing this file — step back and try a fundamentally different approach."
 )
 
+_APT_INSTALL_RE = re.compile(r"\bapt-get\s+install\b")
+_APT_UPDATE_RE = re.compile(r"\bapt-get\s+update\b")
+_APT_STALE_FAILURE_RE = re.compile(
+    r"(404\s+Not\s+Found|Unable\s+to\s+fetch\s+some\s+archives|Hash\s+Sum\s+mismatch|"
+    r"Release\s+file.*expired|repository.*no\s+longer\s+has\s+a\s+Release\s+file)",
+    re.IGNORECASE | re.DOTALL,
+)
+_APT_INSTALL_RECOVERY_HINT = (
+    "\n\n[AptInstallRecovery] This `apt-get install` failure looks like stale package metadata. "
+    "You may run exactly one synchronous `apt-get update`, then retry the same install. "
+    "Do not run `apt-get update` preemptively, do not loop on it, and if the retry fails, "
+    "continue with another valid approach."
+)
+_APT_UPDATE_BLOCKED = (
+    "[AptInstallRecovery] `apt-get update` is blocked until a direct `apt-get install` fails "
+    "with stale package metadata, 404s, hash mismatches, or `Unable to fetch`. "
+    "Try the install directly first. If it already failed with that error, retry with one "
+    "synchronous `apt-get update` and then the same install."
+)
+
+_TOOL_TIMEOUT_RE = re.compile(r"Command timed out after\s+\d+\s+seconds", re.IGNORECASE)
+_HEAVY_INSTALL_RE = re.compile(
+    r"\b(?:apt-get\s+install|apt\s+install|pip3?\s+install|python3?\s+-m\s+pip\s+install|"
+    r"uv\s+pip\s+install|cargo\s+install|make\b)",
+    re.IGNORECASE,
+)
+_TOOL_TIMEOUT_HINT = (
+    "\n\n[ToolTimeoutStrategy] This heavy install/build command timed out. "
+    "Do not repeat the same command with the default Bash timeout. "
+    "If this tool is essential, retry once with Bash timeout=600000 and a brief reason; "
+    "otherwise abandon this path and choose a lighter strategy. "
+    "In either case, do not fall back to unbounded brute force."
+)
+_TOOL_TIMEOUT_BLOCKED = (
+    "[ToolTimeoutStrategy] This heavy install/build command already timed out. "
+    "Do not retry it with the default Bash timeout. If it is essential, retry once with Bash timeout=600000; "
+    "otherwise abandon this path and choose a lighter strategy."
+)
+
+_WORDLIST_RE = re.compile(r"\b(?:wordlist|passwords?|password\.lst|rockyou|dictionary|dict)\b", re.IGNORECASE)
+_EXTERNAL_BRUTE_RE = re.compile(
+    r"\b(?:7z|7za|zip|unzip|rar|unrar|openssl|gpg|hashcat|john)\b|subprocess\.run|os\.system|popen",
+    re.IGNORECASE,
+)
+_LOOP_RE = re.compile(r"\b(?:for|while)\b|for\s+\w+\s+in\s+\w+|enumerate\s*\(", re.IGNORECASE)
+_BOUNDED_BRUTE_RE = re.compile(
+    r"\b(?:head\s+-n?\s*\d+|timeout\s+\d+|counter\s*[<]=?\s*\d+|count\s*[<]=?\s*\d+|"
+    r"range\s*\(\s*\d+\s*\)|islice\s*\()",
+    re.IGNORECASE,
+)
+_STRONG_WORDLIST_SOURCE_RE = re.compile(
+    r"\b(?:password\.lst|rockyou|wordlists?|dictionary|dict)\b|open\s*\(|\bcat\s+",
+    re.IGNORECASE,
+)
+_LITERAL_FOR_IN_RE = re.compile(r"\bfor\s+\w+\s+in\s+([^;\n]+)(?:;|\n)\s*do\b", re.IGNORECASE)
+_LITERAL_FOR_IN_UNSAFE_RE = re.compile(r"[$`*?{}\[\]<>|/&]")
+_LITERAL_FOR_IN_MAX_CANDIDATES = 32
+_SLOW_BRUTEFORCE_BLOCKED = (
+    "[SlowBruteforceGuard] This looks like an unbounded wordlist loop that runs an external command "
+    "for each candidate. Estimate the cost first, run only a bounded sample, or switch to a specialized "
+    "tool/algorithm. Do not spend the task budget on unbounded brute force."
+)
+
+
+def _has_bounded_bruteforce_probe(command: str) -> bool:
+    if _BOUNDED_BRUTE_RE.search(command):
+        return True
+
+    if _STRONG_WORDLIST_SOURCE_RE.search(command):
+        return False
+
+    for match in _LITERAL_FOR_IN_RE.finditer(command):
+        literal_source = match.group(1).strip()
+        if not literal_source or _LITERAL_FOR_IN_UNSAFE_RE.search(literal_source):
+            continue
+
+        try:
+            candidates = shlex.split(literal_source)
+        except ValueError:
+            continue
+
+        if 0 < len(candidates) <= _LITERAL_FOR_IN_MAX_CANDIDATES:
+            return True
+
+    return False
+
 
 _SELF_VERIFY_TOOL = "_tb2_self_verify"
 _SELF_VERIFY_ACK = "Verification check initiated. See the message above for instructions."
@@ -205,6 +292,175 @@ class CustomEditToolProcessor(MultiHookProcessor):
