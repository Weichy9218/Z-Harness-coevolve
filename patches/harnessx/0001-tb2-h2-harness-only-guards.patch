+class AptInstallRecoveryProcessor(MultiHookProcessor):
+    """Gate apt metadata refreshes behind a real stale-index install failure.
+
+    The TB2 prompt discourages wasteful ``apt-get update`` calls, but stale apt
+    indexes are a real sandbox failure mode.  This processor keeps the common
+    path unchanged, blocks preemptive updates, and only relaxes the policy once
+    after an observed install error.
+    """
+
+    _singleton_group = "tb2_apt_install_recovery"
+    _order = 31
+
+    def __init__(self) -> None:
+        self._pending_install_calls: set[str] = set()
+        self._hint_used = False
+        self._update_allowed = False
+        self._update_used = False
+
+    async def on_task_start(self, event: TaskStartEvent):
+        self._pending_install_calls.clear()
+        self._hint_used = False
+        self._update_allowed = False
+        self._update_used = False
+        yield event
+
+    async def on_before_tool(self, event: ToolCallEvent):
+        if event.tool_name == "Bash":
+            command = event.tool_input.get("command", "")
+            if not isinstance(command, str):
+                yield event
+                return
+            has_update = _APT_UPDATE_RE.search(command)
+            has_install = _APT_INSTALL_RE.search(command)
+            if has_update:
+                if self._update_allowed and not self._update_used:
+                    self._update_allowed = False
+                    self._update_used = True
+                else:
+                    yield dataclasses.replace(event, approved=False, synthetic_result=_APT_UPDATE_BLOCKED)
+                    return
+            if has_install:
+                self._pending_install_calls.add(event.tool_call_id)
+        yield event
+
+    async def on_after_tool(self, event: ToolResultEvent):
+        is_tracked_install = event.tool_call_id in self._pending_install_calls
+        self._pending_install_calls.discard(event.tool_call_id)
+        if not is_tracked_install or self._hint_used:
+            yield event
+            return
+
+        output = "\n".join(part for part in (event.result or "", event.error or "") if part)
+        if _APT_STALE_FAILURE_RE.search(output):
+            self._hint_used = True
+            self._update_allowed = True
+            yield dataclasses.replace(event, result=(event.result or "") + _APT_INSTALL_RECOVERY_HINT)
+        else:
+            yield event
+
+    async def on_task_end(self, event: TaskEndEvent):
+        self._pending_install_calls.clear()
+        self._hint_used = False
+        self._update_allowed = False
+        self._update_used = False
+        yield event
+
+
+def _normalized_heavy_command(command: str) -> str:
+    """Normalize a heavy install/build command enough to detect exact retries."""
+    return re.sub(r"\s+", " ", command.strip())
+
+
+class ToolTimeoutStrategyProcessor(MultiHookProcessor):
+    """Nudge away from repeated heavy commands after a tool timeout.
+
+    This processor does not make tools faster and does not solve any task.  It
+    only turns an observed timeout into a bounded retry policy so the model does
+    not burn the remaining budget repeating the same install/build or falling
+    back to unbounded brute force.
+    """
+
+    _singleton_group = "tb2_tool_timeout_strategy"
+    _order = 32
+
+    def __init__(self) -> None:
+        self._pending_commands: dict[str, str] = {}
+        self._timed_out_heavy_commands: set[str] = set()
+        self._long_retry_used: set[str] = set()
+
+    async def on_task_start(self, event: TaskStartEvent):
+        self._pending_commands.clear()
+        self._timed_out_heavy_commands.clear()
+        self._long_retry_used.clear()
+        yield event
+
+    async def on_before_tool(self, event: ToolCallEvent):
+        if event.tool_name != "Bash":
+            yield event
+            return
+
+        command = event.tool_input.get("command", "")
+        if not isinstance(command, str):
+            yield event
+            return
+
+        key = _normalized_heavy_command(command)
+        is_heavy = bool(_HEAVY_INSTALL_RE.search(command))
+        if is_heavy and key in self._timed_out_heavy_commands:
+            timeout = event.tool_input.get("timeout")
+            timeout_ms = int(timeout) if isinstance(timeout, int | str) and str(timeout).isdigit() else 0
+            if timeout_ms >= 600000 and key not in self._long_retry_used:
+                self._long_retry_used.add(key)
+            else:
+                yield dataclasses.replace(event, approved=False, synthetic_result=_TOOL_TIMEOUT_BLOCKED)
+                return
+
+        self._pending_commands[event.tool_call_id] = command
+        yield event
+
+    async def on_after_tool(self, event: ToolResultEvent):
+        command = self._pending_commands.pop(event.tool_call_id, "")
+        output = "\n".join(part for part in (event.result or "", event.error or "") if part)
+        if command and _HEAVY_INSTALL_RE.search(command) and _TOOL_TIMEOUT_RE.search(output):
+            self._timed_out_heavy_commands.add(_normalized_heavy_command(command))
+            yield dataclasses.replace(event, result=(event.result or "") + _TOOL_TIMEOUT_HINT)
+        else:
+            yield event
+
+    async def on_task_end(self, event: TaskEndEvent):
+        self._pending_commands.clear()
+        self._timed_out_heavy_commands.clear()
+        self._long_retry_used.clear()
+        yield event
+
+
+class SlowBruteforceGuardProcessor(MultiHookProcessor):
+    """Block obvious unbounded wordlist × external-command brute force loops."""
+
+    _singleton_group = "tb2_slow_bruteforce_guard"
+    _order = 33
+
+    async def on_task_start(self, event: TaskStartEvent):
+        yield event
+
+    async def on_before_tool(self, event: ToolCallEvent):
+        if event.tool_name != "Bash":
+            yield event
+            return
+
+        command = event.tool_input.get("command", "")
+        if not isinstance(command, str):
+            yield event
+            return
+
+        if (
+            _WORDLIST_RE.search(command)
+            and _LOOP_RE.search(command)
+            and _EXTERNAL_BRUTE_RE.search(command)
+            and not _has_bounded_bruteforce_probe(command)
+        ):
+            yield dataclasses.replace(event, approved=False, synthetic_result=_SLOW_BRUTEFORCE_BLOCKED)
+            return
+
+        yield event
+
+    async def on_task_end(self, event: TaskEndEvent):
+        yield event
+
+
 # ---------------------------------------------------------------------------
 # TaskTimeReminderProcessor
 # ---------------------------------------------------------------------------
@@ -384,7 +640,8 @@ You are an expert software engineer solving terminal-based programming tasks in
    sleep 1 && curl -sf http://localhost:8080/health
 ```
 8. **Do not use unbounded background commands.** If a command's runtime is unpredictable, run it synchronously. Only use `&` / `nohup` for long-running services the verifier will connect to.
-9. **Do not run `apt-get update`.** Package lists are pre-cached — `apt-get install -y <pkg>` works directly and completes in seconds.
+9. **Prefer direct package installs.** Try `apt-get install -y <pkg>` directly first; package lists are usually pre-cached and this completes in seconds. Do not run `apt-get update` preemptively; the harness may block it. If an `apt-get install` fails with stale package metadata, 404s, hash mismatches, or "Unable to fetch", run one synchronous `apt-get update`, then retry the same install once.
+10. **Bound expensive search.** Before running a wordlist, brute-force, or batch command, estimate its cost. Use a small bounded sample first. Do not run an unbounded loop that invokes an external command once per candidate.
 
 ## Definition of Done
 - All required output files exist at the exact paths specified in the task — confirmed with `ls`
