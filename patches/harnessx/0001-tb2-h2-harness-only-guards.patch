+# Copyright 2026 Darwin-Agent
+# SPDX-License-Identifier: MIT
+from __future__ import annotations
+
+from benchmarks.terminal_bench_2.harness import (
+    AptInstallRecoveryProcessor,
+    SlowBruteforceGuardProcessor,
+    ToolTimeoutStrategyProcessor,
+)
+from harnessx.core.events import TaskStartEvent, ToolCallEvent, ToolResultEvent
+
+
+async def _collect(async_iter):
+    return [event async for event in async_iter]
+
+
+async def test_apt_install_recovery_hint_on_stale_install_failure():
+    processor = AptInstallRecoveryProcessor()
+    await _collect(processor.on_task_start(TaskStartEvent(run_id="r", step_id=0)))
+
+    await _collect(
+        processor.on_before_tool(
+            ToolCallEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="install-1",
+                tool_input={"command": "apt-get install -y hashcat"},
+            )
+        )
+    )
+    events = await _collect(
+        processor.on_after_tool(
+            ToolResultEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="install-1",
+                result="E: Failed to fetch http://example/hashcat.deb  404  Not Found\n"
+                "E: Unable to fetch some archives, maybe run apt-get update",
+            )
+        )
+    )
+
+    assert len(events) == 1
+    assert "AptInstallRecovery" in events[0].result
+    assert "apt-get update" in events[0].result
+    assert "retry the same install" in events[0].result
+
+
+async def test_apt_install_recovery_blocks_preemptive_update():
+    processor = AptInstallRecoveryProcessor()
+    await _collect(processor.on_task_start(TaskStartEvent(run_id="r", step_id=0)))
+
+    events = await _collect(
+        processor.on_before_tool(
+            ToolCallEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="update-1",
+                tool_input={"command": "apt-get update && apt-get install -y hashcat"},
+            )
+        )
+    )
+
+    assert len(events) == 1
+    assert not events[0].approved
+    assert "AptInstallRecovery" in (events[0].synthetic_result or "")
+    assert "Try the install directly first" in (events[0].synthetic_result or "")
+
+
+async def test_apt_install_recovery_allows_one_update_after_stale_failure():
+    processor = AptInstallRecoveryProcessor()
+    await _collect(processor.on_task_start(TaskStartEvent(run_id="r", step_id=0)))
+
+    await _collect(
+        processor.on_before_tool(
+            ToolCallEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="install-1",
+                tool_input={"command": "apt-get install -y hashcat"},
+            )
+        )
+    )
+    await _collect(
+        processor.on_after_tool(
+            ToolResultEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="install-1",
+                result="E: Unable to fetch some archives, maybe run apt-get update",
+            )
+        )
+    )
+
+    first_update = await _collect(
+        processor.on_before_tool(
+            ToolCallEvent(
+                run_id="r",
+                step_id=2,
+                tool_name="Bash",
+                tool_call_id="update-1",
+                tool_input={"command": "apt-get update"},
+            )
+        )
+    )
+    second_update = await _collect(
+        processor.on_before_tool(
+            ToolCallEvent(
+                run_id="r",
+                step_id=3,
+                tool_name="Bash",
+                tool_call_id="update-2",
+                tool_input={"command": "apt-get update"},
+            )
+        )
+    )
+
+    assert first_update[0].approved
+    assert second_update[0].approved is False
+
+
+async def test_apt_install_recovery_hint_is_one_shot_per_task():
+    processor = AptInstallRecoveryProcessor()
+    await _collect(processor.on_task_start(TaskStartEvent(run_id="r", step_id=0)))
+
+    for idx in range(2):
+        call_id = f"install-{idx}"
+        await _collect(
+            processor.on_before_tool(
+                ToolCallEvent(
+                    run_id="r",
+                    step_id=idx,
+                    tool_name="Bash",
+                    tool_call_id=call_id,
+                    tool_input={"command": "apt-get install -y hashcat"},
+                )
+            )
+        )
+        events = await _collect(
+            processor.on_after_tool(
+                ToolResultEvent(
+                    run_id="r",
+                    step_id=idx,
+                    tool_name="Bash",
+                    tool_call_id=call_id,
+                    result="E: Unable to fetch some archives, maybe run apt-get update",
+                )
+            )
+        )
+        hint_count = events[0].result.count("AptInstallRecovery")
+        if idx == 0:
+            assert hint_count == 1
+        else:
+            assert hint_count == 0
+
+
+async def test_apt_install_recovery_ignores_non_apt_commands():
+    processor = AptInstallRecoveryProcessor()
+    await _collect(processor.on_task_start(TaskStartEvent(run_id="r", step_id=0)))
+
+    await _collect(
+        processor.on_before_tool(
+            ToolCallEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="grep-1",
+                tool_input={"command": "grep -R password /app"},
+            )
+        )
+    )
+    events = await _collect(
+        processor.on_after_tool(
+            ToolResultEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="grep-1",
+                result="E: Unable to fetch some archives, maybe run apt-get update",
+            )
+        )
+    )
+
+    assert events[0].result == "E: Unable to fetch some archives, maybe run apt-get update"
+
+
+async def test_tool_timeout_strategy_warns_on_heavy_install_timeout():
+    processor = ToolTimeoutStrategyProcessor()
+    await _collect(processor.on_task_start(TaskStartEvent(run_id="r", step_id=0)))
+
+    await _collect(
+        processor.on_before_tool(
+            ToolCallEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="install-1",
+                tool_input={"command": "apt-get install -y hashcat"},
+            )
+        )
+    )
+    events = await _collect(
+        processor.on_after_tool(
+            ToolResultEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="install-1",
+                result="Error: Command timed out after 120 seconds",
+            )
+        )
+    )
+
+    assert "ToolTimeoutStrategy" in events[0].result
+    assert "Bash timeout=600000" in events[0].result
+    assert "do not fall back to unbounded brute force" in events[0].result
+
+
+async def test_tool_timeout_strategy_blocks_default_timeout_retry_after_heavy_install_timeout():
+    processor = ToolTimeoutStrategyProcessor()
+    await _collect(processor.on_task_start(TaskStartEvent(run_id="r", step_id=0)))
+
+    await _collect(
+        processor.on_before_tool(
+            ToolCallEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="install-1",
+                tool_input={"command": "apt-get install -y hashcat"},
+            )
+        )
+    )
+    await _collect(
+        processor.on_after_tool(
+            ToolResultEvent(
+                run_id="r",
+                step_id=1,
+                tool_name="Bash",
+                tool_call_id="install-1",
+                result="Error: Command timed out after 120 seconds",
+            )
+        )
+    )
+
+    blocked_retry = await _collect(
+        processor.on_before_tool(
+            ToolCallEvent(
+                run_id="r",
+                step_id=2,
+                tool_name="Bash",
+                tool_call_id="install-2",
+                tool_input={"command": "apt-get install -y hashcat"},
+            )
+        )
+    )
+    long_retry = await _collect(
+        processor.on_before_tool(
+            ToolCallEvent(
+                run_id="r",
+                step_id=3,
+                tool_name="Bash",
+                tool_call_id="install-3",
